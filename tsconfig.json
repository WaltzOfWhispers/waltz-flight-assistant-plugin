{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "openclaw/plugin-sdk/plugin-entry": ["./types/openclaw-plugin-entry.d.ts"]
    }
  },
  "include": ["index.ts", "types/**/*.d.ts"]
}
